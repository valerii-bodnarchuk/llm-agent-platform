generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  BUYER
  SELLER
  PLATFORM_FEE
  ESCROW
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum CardType {
  DEBIT
  CREDIT
}

enum PayoutStatus {
  PENDING
  ELIGIBLE
  PROCESSING
  PAID
  FAILED
  REVERSED
}

enum SellerStatus {
  ONBOARDING
  PENDING_VERIFICATION
  ACTIVE
  RESTRICTED
  DISABLED
}

enum FraudDecision {
  ALLOW
  REVIEW
  BLOCK
}

model Account {
  id        Int         @id @default(autoincrement())
  name      String?
  type      AccountType @default(BUYER)
  createdAt DateTime    @default(now())
  entries   Entry[]
  seller    Seller?     @relation("SellerAccount")
  allowNegative Boolean @default(false)
}

model Transaction {
  id          Int               @id @default(autoincrement())
  status      TransactionStatus @default(PENDING)
  description String
  createdAt   DateTime          @default(now())
  entries     Entry[]
  payouts     Payout[]
  disputes    Dispute[]
  stripePaymentIntentId String? @unique
}

model Entry {
  id            Int         @id @default(autoincrement())
  amount        Int
  type          CardType
  account       Account     @relation(fields: [accountId], references: [id])
  accountId     Int
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  transactionId Int
  createdAt     DateTime    @default(now())

  @@index([accountId])
  @@index([transactionId])
}

model Payout {
  id                   Int          @id @default(autoincrement())
  status               PayoutStatus @default(PENDING)
  amount               Int
  platformFee          Int
  sellerAmount         Int

  // Stripe
  stripePayoutId       String?      @unique
  stripeTransferId     String?      @unique

  // State tracking
  attempts             Int          @default(0)
  maxAttempts          Int          @default(3)
  failureReason        String?
  lastAttemptAt        DateTime?
  paidAt               DateTime?

  // Relations
  transaction          Transaction  @relation(fields: [transactionId], references: [id])
  transactionId        Int
  seller               Seller       @relation(fields: [sellerId], references: [id])
  sellerId             Int
  escrowAccountId      Int
  platformFeeAccountId Int

  fraudScore           Float?
  fraudDecision        FraudDecision?

  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  
  disputes    Dispute[]

  @@index([status])
  @@index([sellerId])
  @@index([transactionId])
}

model Seller {
  id                    Int          @id @default(autoincrement())
  name                  String
  email                 String       @unique
  status                SellerStatus @default(ONBOARDING)

  // Stripe Connect
  stripeAccountId       String?      @unique
  chargesEnabled        Boolean      @default(false)
  payoutsEnabled        Boolean      @default(false)
  requirementsDue       String[]     // what Stripe needs from seller

  // Relations
  account               Account      @relation("SellerAccount", fields: [accountId], references: [id])
  accountId             Int          @unique
  payouts               Payout[]

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  negativeBalance Int @default(0)
  payoutsBlocked Boolean @default(false)

  @@index([status])
  @@index([stripeAccountId])
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  WON
  LOST
  REFUNDED
}

enum DisputeReason {
  PRODUCT_NOT_RECEIVED
  PRODUCT_UNACCEPTABLE
  FRAUDULENT
  DUPLICATE
  OTHER
}

model Dispute {
  id                   Int           @id @default(autoincrement())
  status               DisputeStatus @default(OPEN)
  reason               DisputeReason
  amount               Int
  description          String?

  // Stripe
  stripeDisputeId      String?       @unique

  // Resolution
  resolvedAt           DateTime?
  resolutionNote       String?

  // Relations
  transaction          Transaction   @relation(fields: [transactionId], references: [id])
  transactionId        Int
  payout               Payout?       @relation(fields: [payoutId], references: [id])
  payoutId             Int?

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([status])
  @@index([transactionId])
}

model InvestigationRun {
  id             Int      @id @default(autoincrement())
  transactionId  Int
  trigger        String
  verdict        String?
  confidence     Float?
  riskLevel      String?
  summary        String?
  verdictPayload Json?
  toolCalls      Json?
  createdAt      DateTime @default(now())
  completedAt    DateTime @default(now())

  auditEntries   InvestigationAuditEntry[]

  @@index([transactionId])
  @@index([verdict])
  @@index([completedAt])
}

model InvestigationAuditEntry {
  id        Int              @id @default(autoincrement())
  run       InvestigationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId     Int
  sequence  Int
  timestamp DateTime
  action    String
  stage     String?
  payload   Json
  createdAt DateTime         @default(now())

  @@unique([runId, sequence])
  @@index([runId])
  @@index([action])
}
